{
  "name": "corretor-no-flow",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:dashboard": "turbo run dev --filter=@corretor/dashboard",
    "dev:web": "turbo run dev --filter=@corretor/web",
    "dev:api": "turbo run dev --filter=@corretor/api",
    "dev:kanban": "node .ai/scripts/kanban-server.mjs",
    "pdf:extract": "node .ai/scripts/extract-pdf-lab.mjs",
    "build": "turbo run build",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "^5"
  },
  "packageManager": "npm@10.9.2",
  "overrides": {
    "postcss": "^8.5.6"
  }
}
