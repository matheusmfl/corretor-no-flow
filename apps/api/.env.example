NODE_ENV=development
PORT=3001

# Prisma — use container names when running via Docker
DATABASE_URL="postgresql://corretor:corretor@postgres:5432/corretor_db?schema=public"

# Redis — usado pelo BullMQ
REDIS_HOST=redis
REDIS_PORT=6379

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d
