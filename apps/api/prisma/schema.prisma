generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum AccountType {
  INDIVIDUAL
  BUSINESS
}

enum TeamSize {
  SOLO
  SMALL_2_5
  MEDIUM_6_20
  LARGE_21_PLUS
}

enum InsuranceProduct {
  AUTO
  HEALTH
  LIFE
  TRAVEL
  HOME
  BUSINESS
  RURAL
}

enum Insurer {
  BRADESCO
  PORTO_SEGURO
  TOKIO_MARINE
  SULAMERICA
  SUHAI
  ALIRO
  ALLIANZ
  YELLOW
}

enum QuoteProcessStatus {
  DRAFT           // criado, aguardando uploads
  PROCESSING      // pelo menos um PDF sendo processado
  PENDING_REVIEW  // todos processados, algum precisa de revisão manual
  READY           // todos prontos, pode gerar
  PUBLISHED       // link gerado e enviado ao segurado
  ARCHIVED
}

enum QuoteStatus {
  PENDING         // aguardando upload do PDF
  PROCESSING      // PDF sendo processado pela IA
  PENDING_REVIEW  // extração incompleta, aguarda revisão do corretor
  READY           // dados confirmados
  FAILED          // falha permanente na extração
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  CANCELED
  EXPIRED
}

enum QuoteEventType {
  PAGE_OPEN
  PAGE_CLOSE
  HEARTBEAT
  INSURER_VIEW    // payload: { insurer: "BRADESCO" }
  PAYMENT_VIEW    // payload: { method: "PIX", installments: 10 }
  WHATSAPP_CLICK
  PDF_DOWNLOAD
}

// ─── Company ──────────────────────────────────────────────────────────────────

model Company {
  id          String      @id @default(cuid())
  accountType AccountType
  legalName   String
  tradeName   String?
  document    String      @unique
  susepNumber String      @unique

  displayName  String
  slug         String   @unique
  logoUrl      String?
  primaryColor String   @default("#3E1010")
  bio          String?

  whatsapp     String
  contactEmail String?
  instagram    String?
  website      String?

  zipCode      String?
  street       String?
  neighborhood String?
  city         String?
  state        String?

  teamSize    TeamSize?
  specialties InsuranceProduct[]

  users            User[]
  quoteProcesses   QuoteProcess[]
  subscription     Subscription?
  onboardingSurvey CompanyOnboardingSurvey?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("companies")
}

// ─── Quote Process ────────────────────────────────────────────────────────────

model QuoteProcess {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  product InsuranceProduct
  status  QuoteProcessStatus @default(DRAFT)

  // Identificação do cliente — opcional, preenchido pelo corretor
  clientName  String?
  clientPhone String?

  // Link público para o segurado
  publicToken String?   @unique
  expiresAt   DateTime?
  openedAt    DateTime?

  quotes   Quote[]
  sessions QuoteSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, createdAt])
  @@map("quote_processes")
}

// ─── Quote (cotação individual por seguradora) ────────────────────────────────

model Quote {
  id        String       @id @default(cuid())
  processId String
  process   QuoteProcess @relation(fields: [processId], references: [id], onDelete: Cascade)

  insurer  Insurer
  status   QuoteStatus @default(PENDING)

  // Nome gerado automaticamente após extração, editável pelo corretor
  // Ex: "Bradesco-Auto-Reduzida", "Porto-Auto-Completa"
  name     String?
  nameSlug String?

  originalFileKey String?
  rawText         String?
  extractedData   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Slug único dentro do mesmo processo
  @@unique([processId, nameSlug])
  @@index([processId])
  @@map("quotes")
}

// ─── Comparison Schema ────────────────────────────────────────────────────────

// Configuração de quais campos são comparáveis por ramo e como rankeá-los.
// Populado via seed — não muda em runtime.
model ComparisonSchema {
  id      String           @id @default(cuid())
  product InsuranceProduct @unique

  // Array de ComparisonField — ver @corretor/types para a estrutura
  // Ex: [{ key: "premium", label: "Prêmio anual", type: "LOWER_IS_BETTER" }, ...]
  fields Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("comparison_schemas")
}

// ─── Plans & Subscriptions ────────────────────────────────────────────────────

model Plan {
  id   String @id @default(cuid())
  name String
  slug String @unique

  quotesPerMonth Int

  // Arrays de InsuranceProduct e Insurer permitidos
  products Json
  insurers Json

  // Feature flags: { customBranding, comparison, openTracking, ... }
  features Json

  isActive      Boolean        @default(true)
  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("plans")
}

model Subscription {
  id        String  @id @default(cuid())
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  planId    String
  plan      Plan    @relation(fields: [planId], references: [id])

  status SubscriptionStatus @default(TRIAL)

  currentPeriodStart DateTime
  currentPeriodEnd   DateTime

  // Resetado no primeiro dia de cada mês via job
  quotesUsedThisMonth Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subscriptions")
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  companyId    String?
  company      Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  quoteSessions       QuoteSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

// ─── Tracking ────────────────────────────────────────────────────────────────

model QuoteSession {
  id        String       @id @default(cuid())
  processId String
  process   QuoteProcess @relation(fields: [processId], references: [id], onDelete: Cascade)

  // UUID gerado no cliente (sessionStorage) — identifica a visita
  sessionId String  @unique
  userId    String?
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  isOwner   Boolean @default(false) // true quando o broker vê a própria cotação

  // Dados técnicos — sem PII
  ipHash    String? // SHA256 do IP (nunca o IP bruto)
  userAgent String?
  referrer  String?

  startedAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now()) // atualizado pelo heartbeat a cada 30s
  endedAt    DateTime? // setado pelo beforeunload

  events QuoteEvent[]

  // Índice para buscar todas as sessões de um processo ordenadas por data
  @@index([processId, startedAt])
  // Índice para filtrar sessões reais (excluindo o próprio corretor)
  @@index([processId, isOwner, startedAt])
  @@map("quote_sessions")
}

model QuoteEvent {
  id        String         @id @default(cuid())
  sessionId String
  session   QuoteSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  type    QuoteEventType
  payload Json?

  createdAt DateTime @default(now())

  // Índice para filtrar eventos por tipo dentro de uma sessão
  @@index([sessionId, type])
  // Índice para análises temporais (ex: quantos WHATSAPP_CLICK por dia)
  @@index([type, createdAt])
  @@map("quote_events")
}

// ─── Onboarding ───────────────────────────────────────────────────────────────

model CompanyOnboardingSurvey {
  id                 String   @id @default(cuid())
  companyId          String   @unique
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  referralSource     String?
  monthlyQuoteVolume String?
  currentTool        String?
  answeredAt         DateTime @default(now())

  @@map("company_onboarding_surveys")
}
